# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Thirdweb Configuration
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id_here
THIRDWEB_SECRET_KEY=your_thirdweb_secret_key_here

# TestFlight / App Store Connect Configuration
APP_STORE_CONNECT_KEY_ID=your_app_store_connect_key_id_here
APP_STORE_CONNECT_ISSUER_ID=your_app_store_connect_issuer_id_here
APP_STORE_CONNECT_PRIVATE_KEY=base64_encoded_or_raw_p8_private_key_here
APP_STORE_CONNECT_APP_ID=your_app_apple_id_here
# Optional: pin a specific external TestFlight beta group. If omitted, the first external group is used.
APP_STORE_CONNECT_BETA_GROUP_ID=
NEXT_PUBLIC_TESTFLIGHT_URL=https://testflight.apple.com/join/your_public_link

# Referral beta claim security
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
# Set to false for local-only testing if Turnstile is not configured.
REFERRAL_CLAIM_CAPTCHA_REQUIRED=true

# Android beta access
# Requires an approved Google Play testing track and opt-in URL before instant Android installs work.
NEXT_PUBLIC_ANDROID_PLAY_TESTING_URL=https://play.google.com/apps/testing/app.bearo.cash

# Admin API Configuration
ADMIN_API_KEY=your_admin_api_key_here

# API Configuration (optional - defaults to /api)
NEXT_PUBLIC_API_URL=/api
