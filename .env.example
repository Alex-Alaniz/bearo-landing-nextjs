# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Thirdweb Configuration
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id_here
THIRDWEB_SECRET_KEY=your_thirdweb_secret_key_here

# API Configuration (optional - defaults to /api)
NEXT_PUBLIC_API_URL=/api

# Solana RPC (optional - defaults to public mainnet RPC)
# Prefer a dedicated provider here; the public mainnet endpoint can return HTTP 429.
SOLANA_RPC_URLS=https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Holder Radar indexer refresh
# Used by /holders/live and protected /api/bearco/live-holders/refresh.
HELIUS_API_KEY=your_helius_api_key
CRON_SECRET=replace_with_a_long_random_secret
# Optional manual-refresh override. If both are set, CRON_SECRET wins so
# Vercel Cron's Authorization header works automatically.
BEARCO_RADAR_CRON_SECRET=
BEARCO_RADAR_REFRESH_LIMIT=250
BEARCO_RADAR_EVENT_WALLET_LIMIT=25

# Holder access sessions (recommended in production)
BEARCO_SESSION_SECRET=replace_with_a_long_random_secret
BEARCO_SOCIAL_AUTH_SECRET=replace_with_a_second_long_random_secret
BEARCO_SITE_URL=http://localhost:3000
# Credits Streamflow lock contracts from source wallets to claimed profile wallets.
# Format: claimed_wallet=streamflow_lock_wallet[,other_lock_wallet];...
BEARCO_STREAMFLOW_LOCK_WALLET_ALIASES=

# Privy holder social authentication (preferred)
# Enable X, Telegram, Discord, and email login methods in the Privy
# dashboard. Enable identity tokens so the API can verify linked accounts.
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_ID=your_privy_app_id
# Optional: the API derives this from PRIVY_APP_ID by default.
PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/your_privy_app_id/jwks.json
# Optional overrides if you prefer key/secret verification instead of JWKS.
PRIVY_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
PRIVY_APP_SECRET=your_privy_app_secret

# Holder social authentication fallback
# X uses OAuth 2.0 authorization code + PKCE. Client secret is optional for
# public-client apps and recommended for confidential web apps.
BEARCO_X_CLIENT_ID=your_x_oauth_client_id
BEARCO_X_CLIENT_SECRET=your_x_oauth_client_secret

# Telegram Login uses OIDC authorization code + PKCE.
# Register allowed URLs in BotFather Web Login first.
BEARCO_TELEGRAM_CLIENT_ID=your_telegram_web_login_client_id
BEARCO_TELEGRAM_CLIENT_SECRET=your_telegram_web_login_client_secret

# Telegram bot operations and Privy Telegram linking.
BEARCO_TELEGRAM_BOT_TOKEN=your_telegram_bot_token
BEARCO_TELEGRAM_WEBHOOK_SECRET=replace_with_a_long_random_secret

# Discord uses OAuth2 authorization code with the identify scope.
BEARCO_DISCORD_CLIENT_ID=your_discord_client_id
BEARCO_DISCORD_CLIENT_SECRET=your_discord_client_secret

# Holder room community destinations
NEXT_PUBLIC_BEARCO_TELEGRAM_HOLDER_URL=https://t.me/your_public_holder_channel
NEXT_PUBLIC_BEARCO_DISCORD_HOLDER_URL=https://discord.gg/your_holder_server
NEXT_PUBLIC_BEARCO_TELEGRAM_ROOM_1_URL=
NEXT_PUBLIC_BEARCO_TELEGRAM_ROOM_2_URL=
NEXT_PUBLIC_BEARCO_TELEGRAM_ROOM_3_URL=
NEXT_PUBLIC_BEARCO_TELEGRAM_ROOM_5_URL=
NEXT_PUBLIC_BEARCO_TELEGRAM_ROOM_10_URL=
NEXT_PUBLIC_BEARCO_DISCORD_ROOM_1_URL=
NEXT_PUBLIC_BEARCO_DISCORD_ROOM_2_URL=
NEXT_PUBLIC_BEARCO_DISCORD_ROOM_3_URL=
NEXT_PUBLIC_BEARCO_DISCORD_ROOM_5_URL=
NEXT_PUBLIC_BEARCO_DISCORD_ROOM_10_URL=

# PumpSwap liquidity planning
NEXT_PUBLIC_BEARCO_PUMPSWAP_POOL=BakErJmVtygmYPQvA8avwgqHif2zbGxRs6DD3RNVHHVF
NEXT_PUBLIC_BEARCO_PUMPSWAP_LP_MINT=G35NRNmYA89SSP8LUXV1zWkUyg8cZPQxBJWxp22hPBq8
